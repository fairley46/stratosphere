{
  "name": "stratosphere",
  "private": true,
  "version": "0.1.0",
  "description": "Stratosphere — AI-driven VM to Kubernetes migration architect.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "test": "npm run build && node --test tests/**/*.test.mjs",
    "test:coverage": "npm run build && node --experimental-test-coverage --test-coverage-include='packages/engine/dist/**/*.js' --test-coverage-exclude='packages/engine/dist/repository-export.js' --test-coverage-lines=99 --test tests/**/*.test.mjs",
    "ci": "npm run test:coverage",
    "stratosphere": "npm --workspace @stratosphere/bin run run --",
    "mcp:start": "npm --workspace @stratosphere/bin run mcp",
    "doctor": "npm --workspace @stratosphere/bin run doctor --",
    "binary:build": "npm --workspace @stratosphere/bin run build:binary",
    "binary:linux-x64": "npm --workspace @stratosphere/bin run build:binary:linux-x64",
    "binary:linux-arm64": "npm --workspace @stratosphere/bin run build:binary:linux-arm64",
    "demo": "bash scripts/demo.sh"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
