{
  "name": "stratosphere",
  "private": true,
  "version": "0.1.0",
  "description": "Stratosphere — AI-driven VM to Kubernetes migration architect.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "test": "npm run build && node --test tests/**/*.test.mjs",
    "ci": "npm run build && npm run test",
    "stratosphere": "npm --workspace @stratosphere/cli run run --",
    "mcp:start": "npm --workspace @stratosphere/mcp run start"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
